{
  "name": "specstitch",
  "version": "0.1.0",
  "description": "Local-first traceability quilt for PRDs, tasks, docs, tests, and source drift.",
  "type": "module",
  "bin": {
    "specstitch": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm pack --dry-run && npm run package:smoke",
    "package:smoke": "npm pack --dry-run"
  },
  "keywords": [
    "traceability",
    "prd",
    "requirements",
    "cli",
    "drift",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/specstitch.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/specstitch/issues"
  },
  "homepage": "https://github.com/rogerchappel/specstitch#readme"
}
